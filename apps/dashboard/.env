# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/whatsapp_ai
DATABASE_POOL_SIZE=10
DATABASE_MIN_POOL=2
DATABASE_MAX_POOL=20
DATABASE_SSL=false

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=whatsapp_ai_platform
MONGODB_POOL_MIN=5
MONGODB_POOL_MAX=50

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_POOL_SIZE=10

# JWT Authentication
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=placeholder
WHATSAPP_BUSINESS_ACCOUNT_ID=placeholder
WHATSAPP_ACCESS_TOKEN=placeholder
WHATSAPP_WEBHOOK_VERIFY_TOKEN=placeholder

# Vector Database (Qdrant)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=placeholder
VECTOR_DIMENSIONS=1536

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_FREE=price_placeholder
STRIPE_PRICE_PRO=price_placeholder
STRIPE_PRICE_ENTERPRISE=price_placeholder

# Google Calendar OAuth
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Outlook Calendar OAuth
OUTLOOK_CLIENT_ID=placeholder
OUTLOOK_CLIENT_SECRET=placeholder
OUTLOOK_REDIRECT_URI=http://localhost:3001/api/auth/outlook/callback

# AWS
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_REGION=us-east-1
AWS_S3_BUCKET=placeholder

# CDN Configuration
CDN_ENABLED=false
CDN_PROVIDER=cloudfront
CDN_DOMAIN=placeholder.cloudfront.net
CDN_INVALIDATE_ON_DEPLOY=true
CDN_IMAGE_DOMAINS=localhost,wa.me,whatsapp.com,fb.com,messenger.com

# CloudFront
CLOUDFRONT_DOMAIN=placeholder.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Cloudflare (alternative)
CLOUDFLARE_DOMAIN=cdn.example.com
CLOUDFLARE_ZONE_ID=abc123def456
CLOUDFLARE_API_KEY=placeholder

# Grafana
GRAFANA_PASSWORD=admin

# ElevenLabs Voice
ELEVENLABS_API_KEY=placeholder

# Temporal Workflow
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=whatsapp-ai-platform

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_ENABLED=false
SENTRY_INCLUDE_LOCAL_VARIABLES=true
